# ===========================================
# GenNovelWeb BFF 配置文件示例
# ===========================================
# 复制此文件为 .env 并填写实际配置
# cp .env.example .env

# 环境: development / production
ENV=development

# 服务端口
PORT=8080

# ===========================================
# PostgreSQL 数据库配置
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=postgres
DB_SSL_MODE=disable

# ===========================================
# Redis 配置
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# JWT 认证配置
# ===========================================
# 生产环境请更换为随机生成的强密钥（至少32字符）
JWT_SECRET=your-super-secret-key-change-in-production

# Access Token 有效期（分钟）
JWT_ACCESS_TOKEN_TTL=15

# Refresh Token 有效期（天）
JWT_REFRESH_TOKEN_TTL=7

# ===========================================
# 算法后端配置
# ===========================================
ALGORITHM_BASE_URL=http://localhost:8000
ALGORITHM_TIMEOUT=30
